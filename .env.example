# ──────────────────────────────────────────────────────────────
#  LLM Observability Audit Platform — Environment Template
# ──────────────────────────────────────────────────────────────
#
#  Setup:
#   1. cp .env.example .env
#   2. Generate 7 ACL passwords (see one-liner below)
#   3. Paste each generated password into BOTH .env AND
#      config/redis-acl.conf (the >password field for each user)
#   4. NEVER commit .env — it is in .gitignore
#
#  Password generation (cross-platform, no openssl required):
#
#      python -c "import secrets; roles=['DIRECTOR','AUDITOR_TRACE', \
#        'AUDITOR_SAFETY','AUDITOR_POLICY','AUDITOR_HALLUCINATION', \
#        'AUDITOR_DRIFT','AUDITOR_COST']; \
#        [print(f'REDIS_{r}_PASSWORD=\"{secrets.token_urlsafe(32)}\"') for r in roles]"
#
# ── Service endpoints ────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
QDRANT_URL="http://localhost:6333"

# Optional: embedded QDrant file path (used if QDRANT_URL server is unreachable)
# QDRANT_PATH="./data/qdrant"

# Optional: override default SQLite audit store path (default: ./data/audit.db)
# AUDIT_DB_PATH="./data/audit.db"

# ── Redis ACL passwords ─────────────────────────────────────
# These MUST match the passwords in config/redis-acl.conf exactly.
# Use the one-liner above to generate all 7 at once.
REDIS_DIRECTOR_PASSWORD="CHANGE_ME_DIRECTOR_PASSWORD"
REDIS_AUDITOR_TRACE_PASSWORD="CHANGE_ME_TRACE_PASSWORD"
REDIS_AUDITOR_SAFETY_PASSWORD="CHANGE_ME_SAFETY_PASSWORD"
REDIS_AUDITOR_POLICY_PASSWORD="CHANGE_ME_POLICY_PASSWORD"
REDIS_AUDITOR_HALLUCINATION_PASSWORD="CHANGE_ME_HALLUCINATION_PASSWORD"
REDIS_AUDITOR_DRIFT_PASSWORD="CHANGE_ME_DRIFT_PASSWORD"
REDIS_AUDITOR_COST_PASSWORD="CHANGE_ME_COST_PASSWORD"

# ── OpenTelemetry (optional) ────────────────────────────────
# OTEL_SERVICE_NAME="llm-observability"
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
# OTEL_EXPORT_MODE="none"   # none | console | otlp | prometheus
