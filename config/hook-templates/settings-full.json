{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/settings.schema.json",
  "$comment": "Full audit hook configuration. Shell form: a single command string per hook, with the ${CLAUDE_PROJECT_DIR} placeholder (expanded by Claude Code to the project root) so hooks resolve even when a build step runs from a subdirectory (e.g. cd webapp). Shell form is honored by every Claude Code version (exec form's args array is dropped by older runtimes). The '|| true' keeps a hook from ever blocking a tool. Copy as-is into .claude/settings.json.",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR}/observability/hooks/version_archive.py\" || true",
            "statusMessage": "Archiving agent definition changes...",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR}/observability/hooks/directive_intake.py\" || true",
            "statusMessage": "Checking for audit directives...",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR}/observability/hooks/test_runner.py\" || true",
            "statusMessage": "Running tests + tracking bugs...",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR}/observability/hooks/post_tool_use.py\" || true",
            "statusMessage": "Recording telemetry...",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR}/observability/hooks/session_end.py\" || true",
            "statusMessage": "Finalizing session telemetry...",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
