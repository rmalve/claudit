{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/settings.schema.json",
  "$comment": "Full audit hook configuration. Exec form (command + args) with the ${CLAUDE_PROJECT_DIR} placeholder, which Claude Code expands to the project root regardless of the shell's working directory — so hooks resolve even when a build step runs from a subdirectory (e.g. cd webapp). No manual path substitution needed; copy as-is into .claude/settings.json.",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/observability/hooks/version_archive.py"],
            "statusMessage": "Archiving agent definition changes...",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/observability/hooks/directive_intake.py"],
            "statusMessage": "Checking for audit directives...",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/observability/hooks/test_runner.py"],
            "statusMessage": "Running tests + tracking bugs...",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/observability/hooks/post_tool_use.py"],
            "statusMessage": "Recording telemetry...",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/observability/hooks/session_end.py"],
            "statusMessage": "Finalizing session telemetry...",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
