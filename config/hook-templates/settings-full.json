{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/settings.schema.json",
  "$comment": "Full audit hook configuration. Each hook-event array holds matcher groups, and every group carries a nested 'hooks' array — this is what Claude Code's schema requires. Replace {OBSERVABILITY_PATH} with the absolute path to the llm-observability repo.",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"{OBSERVABILITY_PATH}/observability/hooks/version_archive.py\"",
            "statusMessage": "Archiving agent definition changes...",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"{OBSERVABILITY_PATH}/observability/hooks/directive_intake.py\"",
            "statusMessage": "Checking for audit directives...",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"{OBSERVABILITY_PATH}/observability/hooks/test_runner.py\"",
            "statusMessage": "Running tests + tracking bugs...",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"{OBSERVABILITY_PATH}/observability/hooks/post_tool_use.py\"",
            "statusMessage": "Recording telemetry...",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"{OBSERVABILITY_PATH}/observability/hooks/session_end.py\"",
            "statusMessage": "Finalizing session telemetry...",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
