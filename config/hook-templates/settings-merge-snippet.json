{
  "$comment": "Merge snippet — add these matcher groups to your existing hooks object in .claude/settings.json. Combine the per-event arrays; do NOT replace your entire settings file. Shell form: a single command string per hook with the ${CLAUDE_PROJECT_DIR} placeholder so hooks resolve from any working directory and on any Claude Code version (no manual path substitution).",

  "hooks_to_merge": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR}/observability/hooks/version_archive.py\" || true",
            "statusMessage": "Archiving agent definition changes...",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR}/observability/hooks/directive_intake.py\" || true",
            "statusMessage": "Checking for audit directives...",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR}/observability/hooks/test_runner.py\" || true",
            "statusMessage": "Running tests + tracking bugs...",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR}/observability/hooks/post_tool_use.py\" || true",
            "statusMessage": "Recording telemetry...",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR}/observability/hooks/session_end.py\" || true",
            "statusMessage": "Finalizing session telemetry...",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
