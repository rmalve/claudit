{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/settings.schema.json",
  "$comment": "Telemetry-only hook configuration (no directive delivery). Use this when you want to collect data but are not yet ready to receive audit directives. Each hook-event array holds matcher groups with a nested 'hooks' array. Replace {OBSERVABILITY_PATH} with the absolute path to the llm-observability repo.",

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"{OBSERVABILITY_PATH}/observability/hooks/post_tool_use.py\"",
            "statusMessage": "Recording telemetry...",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"{OBSERVABILITY_PATH}/observability/hooks/session_end.py\"",
            "statusMessage": "Finalizing session telemetry...",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
