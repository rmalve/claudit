{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/settings.schema.json",
  "$comment": "Telemetry-only hook configuration (no directive delivery). Use when you want data collection but are not yet ready to receive audit directives. Exec form with the ${CLAUDE_PROJECT_DIR} placeholder so hooks resolve from any working directory. Copy as-is into .claude/settings.json.",

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/observability/hooks/post_tool_use.py"],
            "statusMessage": "Recording telemetry...",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/observability/hooks/session_end.py"],
            "statusMessage": "Finalizing session telemetry...",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
